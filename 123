# ============================================
# UnixNodes VPS Bot Configuration
# Version: 7.1-PRO
# ============================================

# ============================================
# DISCORD BOT CONFIGURATION (REQUIRED)
# ============================================

# Your Discord Bot Token (REQUIRED)
# Get this from: https://discord.com/developers/applications
# 1. Go to Discord Developer Portal
# 2. Select your application
# 3. Go to "Bot" section
# 4. Click "Reset Token" or "Copy" to get your token
# IMPORTANT: Never share this token publicly!
DISCORD_TOKEN=your_bot_token

# Bot Display Name
# This appears in embeds and messages
BOT_NAME=BOt_name

# Command Prefix
# The character(s) users type before commands
# Examples: ! (default), ?, ., $
PREFIX=!

# Bot Version
# Displayed in bot information
BOT_VERSION=v1.0-PRO

# Bot Developer Name
# Your name or organization
BOT_DEVELOPER=Hopingboz

# ============================================
# ADMIN CONFIGURATION (REQUIRED)
# ============================================

# Main Admin Discord User ID (REQUIRED)
# This is YOUR Discord user ID (the bot owner)
# How to get your Discord ID:
# 1. Enable Developer Mode in Discord (Settings > Advanced > Developer Mode)
# 2. Right-click your username
# 3. Click "Copy ID"
# Example: 123456789012345678
MAIN_ADMIN_ID=1210291131301101618

# VPS User Role ID (OPTIONAL)
# Discord role ID for VPS users
# Leave as 0 to auto-create the role
# How to get role ID:
# 1. Enable Developer Mode
# 2. Right-click the role in Server Settings
# 3. Click "Copy ID"
VPS_USER_ROLE_ID=0

# ============================================
# SERVER CONFIGURATION
# ============================================

# Your Server's Public IP Address
# This is used for port forwarding information
# Users will connect to: YOUR_SERVER_IP:port
# Examples: 
# - Public IP: 203.0.113.45
# - Domain: vps.example.com
# - Localhost (testing): 127.0.0.1
YOUR_SERVER_IP=127.0.0.1

# Default LXC Storage Pool
# The storage pool name used for VPS containers
# Common values: default, local, zfs, btrfs
# Check available pools with: lxc storage list
DEFAULT_STORAGE_POOL=default

# ============================================
# RESOURCE MONITORING THRESHOLDS
# ============================================

# CPU Usage Threshold (Percentage)
# VPS exceeding this will be flagged/suspended
# Default: 90 (90%)
# Range: 1-100
CPU_THRESHOLD=90

# RAM Usage Threshold (Percentage)
# VPS exceeding this will be flagged/suspended
# Default: 90 (90%)
# Range: 1-100
RAM_THRESHOLD=90

# ============================================
# COINS & ECONOMY SYSTEM (NEW!)
# ============================================

# Coin Earning Rates
COINS_PER_INVITE=50
COINS_PER_MESSAGE=1
COINS_PER_VOICE_MINUTE=2
COINS_DAILY_REWARD=100

# VPS Renewal Costs (in coins)
COINS_VPS_RENEWAL_1DAY=50
COINS_VPS_RENEWAL_7DAYS=350
COINS_VPS_RENEWAL_30DAYS=1500

# VPS Expiration Settings
DEFAULT_VPS_DURATION_DAYS=7
VPS_EXPIRY_WARNING_HOURS=24

# Cooldowns and Limits
MESSAGE_COOLDOWN_SECONDS=60
VOICE_MIN_DURATION_MINUTES=5
LEADERBOARD_TOP_COUNT=10

# ============================================
# OPTIONAL: REMOTE NODE CONFIGURATION
# ============================================